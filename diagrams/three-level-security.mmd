%% AGF Three-Level Security Model
%% Level 1: Security Fabric (enforcement), Level 2: Security Governance (policy), Level 3: Security Intelligence (detection)
%% Shows normal path vs Security Response Bus fast-path

graph TD
    THREAT["Threat / Event"] --> L1

    subgraph L1["Level 1: Security Fabric — Enforcement"]
        direction LR
        L1_desc["Always active · Synchronous · Wire-speed"]
        L1_a["Input<br/>Sanitization"]
        L1_b["Output<br/>Scanning"]
        L1_c["Runtime<br/>Containment"]
        L1_d["Identity<br/>Verification"]
        L1_e["Configuration<br/>Attestation"]
        L1_f["Ring Integrity<br/>Verification"]
    end

    subgraph L2["Level 2: Security Governance — Policy Evaluation"]
        direction LR
        L2_desc["Ring 2 · Policy as Code #9 · Governance Gates #8"]
        L2_a["Access Control<br/>Policy"]
        L2_b["Data<br/>Classification"]
        L2_c["Irreversible Action<br/>Authorization"]
        L2_d["Supply Chain<br/>Trust Policy"]
        L2_e["Semantic Security<br/>Evaluation"]
    end

    subgraph L3["Level 3: Security Intelligence — Detection & Response"]
        direction LR
        L3_desc["SIEM for agents · Dual-speed operation"]
        L3_a["Behavioral Anomaly<br/>Detection"]
        L3_b["Cross-Pipeline<br/>Correlation"]
        L3_c["Memory & State<br/>Introspection"]
        L3_d["Human-Agent<br/>Interaction Analysis"]
        L3_e["Response<br/>Playbooks"]
    end

    %% Normal path (slow)
    L1 -- "syntactically clean<br/>but suspicious" --> L2
    L2 -- "needs deeper<br/>analysis" --> L3
    L3 -- "detection signal" --> L2
    L2 -- "authorized<br/>response" --> L1
    L1 --> CONTAIN_NORMAL["Containment<br/>Executed"]

    %% Security Response Bus (fast path)
    L3 == "PRE-AUTHORIZED<br/>MATCH" ==> SRB

    subgraph SRB["Security Response Bus"]
        direction LR
        SRB_desc["Pre-authorized fast-path · Sub-second"]
        SRB_match["Pattern matches<br/>pre-authorized class"]
        SRB_signal["Containment signal<br/>sent directly"]
    end

    SRB == "DIRECT<br/>CONTAINMENT" ==> L1
    SRB -. "post-facto<br/>notification" .-> L2
    L1 --> CONTAIN_FAST["Fast-Path<br/>Containment"]

    %% Dual-speed indicators
    FAST["Fast Path Sentinels<br/>Sub-second · Known patterns"] -.- L3
    SLOW["Slow Path Analysis<br/>Hours-days · Behavioral drift"] -.- L3

    %% Styles
    style L1 fill:#E74C3C,stroke:#C0392B,color:#fff
    style L2 fill:#F39C12,stroke:#D68910,color:#fff
    style L3 fill:#3498DB,stroke:#2471A3,color:#fff
    style SRB fill:#E74C3C,stroke:#922B21,color:#fff,stroke-width:3px
    style CONTAIN_FAST fill:#922B21,stroke:#641E16,color:#fff
    style CONTAIN_NORMAL fill:#C0392B,stroke:#922B21,color:#fff
    style THREAT fill:#7B241C,stroke:#512E5F,color:#fff
    style FAST fill:#2E86C1,stroke:#1B4F72,color:#fff
    style SLOW fill:#1A5276,stroke:#0E2F44,color:#fff
