%% AGF Agent Environment Stack — 5-Layer Model with Trust Boundary
%% L1 Identity → L2 Instructions → L3 Capabilities → L4 Context → L5 Session
%% Trust boundary between L2 (trusted) and L3 (untrusted)
%% Environment Optimization Loop

graph TD
    subgraph STACK["Agent Environment Stack — #19"]
        direction TB

        L5["<b>L5: Session State</b> — 20-30%<br/>Conversation history, tool results,<br/>working memory, handoff context<br/><i>Ephemeral, session-scoped</i>"]

        L4["<b>L4: Retrieved Context</b> — 30-40%<br/>Task-specific knowledge, documents,<br/>search results<br/><i>Dynamic, loaded JIT per task</i>"]

        L3["<b>L3: Capability Set</b> — 10-15%<br/>Active tools, skills, MCP servers,<br/>API access<br/><i>Provisioned per role, trust-gated</i>"]

        TB["═══ TRUST BOUNDARY ═══<br/>Above: dynamic, untrusted<br/>Below: human-authored, trusted"]

        L2["<b>L2: Instruction Architecture</b> — 10-20%<br/>System prompts, rules, personas,<br/>constraints<br/><i>Versioned, tested, slow-changing</i>"]

        L1["<b>L1: Identity & Policy Substrate</b> — 5-10%<br/>Agent identity, ring assignment,<br/>governance policy, trust level<br/><i>Foundational</i>"]

        L5 --- L4 --- L3 --- TB --- L2 --- L1
    end

    %% Composition flow
    COMPOSE["Composition flow: bottom-up ▲"] --> L1

    %% Security Fabric enforcement at trust boundary
    SF["Security Fabric<br/>Enforces trust boundary<br/>Treats L3-L5 as untrusted input"] -.- TB

    subgraph LOOP["Environment Optimization Loop"]
        direction LR
        OBS["Observe<br/><i>context hit rate,<br/>tool accuracy,<br/>token efficiency</i>"]
        IDE["Identify<br/><i>missing context,<br/>unused tools,<br/>stale instructions</i>"]
        PRO["Propose<br/><i>updated instructions,<br/>revised tool sets,<br/>adjusted priorities</i>"]
        VAL["Validate<br/><i>Ring 2 policy check<br/>#18 regression test<br/>security review</i>"]
        DEP["Deploy<br/><i>staged rollout<br/>with monitoring<br/>and rollback</i>"]

        OBS --> IDE --> PRO --> VAL --> DEP
        DEP -- "next cycle" --> OBS
    end

    LOOP -. "improves" .-> STACK
    VAL -- "rejected ×3 →<br/>pause for<br/>human review" --> PAUSE["Human Review"]

    %% Styles
    style L5 fill:#3498DB,stroke:#2471A3,color:#fff
    style L4 fill:#2E86C1,stroke:#1A5276,color:#fff
    style L3 fill:#2874A6,stroke:#1B4F72,color:#fff
    style TB fill:#E74C3C,stroke:#C0392B,color:#fff,stroke-width:3px
    style L2 fill:#27AE60,stroke:#1E8449,color:#fff
    style L1 fill:#1E8449,stroke:#145A32,color:#fff
    style STACK fill:#2C3E50,stroke:#1A252F,color:#fff
    style LOOP fill:#34495E,stroke:#1C2833,color:#fff
    style SF fill:#C0392B,stroke:#922B21,color:#fff
    style COMPOSE fill:#7F8C8D,stroke:#566573,color:#fff
    style PAUSE fill:#F39C12,stroke:#D68910,color:#fff

    style OBS fill:#5DADE2,stroke:#2E86C1,color:#fff
    style IDE fill:#48C9B0,stroke:#1ABC9C,color:#fff
    style PRO fill:#F4D03F,stroke:#D4AC0D,color:#000
    style VAL fill:#E8A838,stroke:#B07820,color:#fff
    style DEP fill:#58D68D,stroke:#2ECC71,color:#fff
