%% AGF Composition Patterns — Progressive governance from MVC to Full Governed
%% Shows which primitives compose at each level and which rings activate

graph LR
    subgraph MVC["Minimum Viable Control"]
        direction TB
        MVC_rings["Rings: minimal"]
        MVC_p1["#7 Bounded Agency"]
        MVC_p2["#14 Identity & Attribution"]
        MVC_p3["#6 Provenance Chains"]
        MVC_p4["#10 Event-Driven Observability"]
        MVC_p5["#19 Environment Governance<br/><i>minimal</i>"]
        MVC_val["Agents scoped, actions attributable,<br/>audit trail, visibility"]
    end

    subgraph VP["Validation Pipeline"]
        direction TB
        VP_rings["Rings: 0 + 1"]
        VP_p1["+ #1 Separation of<br/>Producer & Verifier"]
        VP_p2["+ #2 Validation Loops"]
        VP_p3["+ #5 Structured Output"]
        VP_p4["+ #13 Error Handling"]
        VP_val["Verified outputs before release"]
    end

    subgraph GDF["Governed Decision Flow"]
        direction TB
        GDF_rings["Rings: 0 + 1 + 2"]
        GDF_p1["+ #8 Governance Gates"]
        GDF_p2["+ #9 Policy as Code"]
        GDF_p3["+ #16 Transaction Control"]
        GDF_p4["+ #17 Data Governance"]
        GDF_val["Policy-evaluated, human-gateable<br/>decisions with side-effect mgmt"]
    end

    subgraph SGS["Secure Governed System"]
        direction TB
        SGS_rings["Rings: 0 + 1 + 2 + Security"]
        SGS_p1["+ #15 Adversarial Robustness"]
        SGS_p2["+ #18 Evaluation & Assurance"]
        SGS_p3["+ #11 Trust Ladders"]
        SGS_p4["+ Zero Trust at every boundary"]
        SGS_val["Defense in depth, pre-deploy<br/>validation, production-grade"]
    end

    subgraph FGAS["Full Governed Agentic System"]
        direction TB
        FGAS_rings["Rings: 0 + 1 + 2 + 3 + Fabric"]
        FGAS_p1["+ #3 Self-Improving Cycles"]
        FGAS_p2["+ #4 Adversarial Critique"]
        FGAS_p3["+ #12 Memory-Augmented Reasoning"]
        FGAS_p4["+ #19 full optimization loop"]
        FGAS_val["Complete governance for high-stakes,<br/>regulated, enterprise-grade systems"]
    end

    MVC --> VP --> GDF --> SGS --> FGAS

    %% Styles
    style MVC fill:#3498DB,stroke:#2471A3,color:#fff
    style VP fill:#2ECC71,stroke:#27AE60,color:#fff
    style GDF fill:#F39C12,stroke:#D68910,color:#fff
    style SGS fill:#E74C3C,stroke:#C0392B,color:#fff
    style FGAS fill:#9B59B6,stroke:#7D3C98,color:#fff

    style MVC_rings fill:#2980B9,stroke:#1F618D,color:#fff
    style VP_rings fill:#27AE60,stroke:#1E8449,color:#fff
    style GDF_rings fill:#E67E22,stroke:#CA6F1E,color:#fff
    style SGS_rings fill:#CB4335,stroke:#A93226,color:#fff
    style FGAS_rings fill:#884EA0,stroke:#6C3483,color:#fff
